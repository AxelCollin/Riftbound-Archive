generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum CardRarity {
  COMMON
  UNCOMMON
  RARE
  EPIC
  ULTIMATE
  UNKNOWN
}

enum CardKind {
  GAMEPLAY
  ENERGY
  TOKEN
  RULES
}

enum CardVariant {
  NORMAL
  FOIL
  SHOWCASE
}

enum CardPrintTreatment {
  REGULAR
  ALT
  OVERNUMBER
  UNKNOWN
}

enum CollectionTransactionType {
  ADD
  REMOVE
  SET
  ADJUST
}

enum BinderOverrideMode {
  AUTO
  DISABLED
  FORCE_VARIANT
}

enum DeckStatus {
  THEORETICAL
  ASSEMBLED
  ARCHIVED
}

enum DeckAllocationStrategy {
  PRESERVE_PREMIUM_VARIANTS
  EXACT_VARIANT
  ANY_VARIANT
}

enum DeckCardVariantPreference {
  ANY
  NORMAL
  FOIL
  SHOWCASE
}

enum BoosterIntervalUnit {
  DAY
  WEEK
  MONTH
}

enum BoosterCounterEventType {
  ACCRUAL
  MANUAL_ADJUSTMENT
  OPENING_DECREMENT
  ROLLBACK
}

enum BoosterOpeningStatus {
  RECORDED
  ROLLED_BACK
}

model AppSetting {
  key       String   @id
  jsonValue String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Set {
  id         String    @id
  code       String    @unique
  name       String
  releasedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  cards      Card[]
}

model Card {
  id                     String                  @id
  setId                  String
  set                    Set                     @relation(fields: [setId], references: [id])
  collectorNumber        String?
  name                   String
  rarity                 CardRarity              @default(UNKNOWN)
  officialRarityRaw      String?
  kind                   CardKind
  printTreatment         CardPrintTreatment      @default(REGULAR)
  printTreatmentRaw      String?
  hasShowcase            Boolean                 @default(false)
  officialImageUrl       String?
  officialArtist         String?
  officialRawJson        Json?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  translations           CardTranslation[]
  collectionEntries      CollectionEntry[]
  collectionTransactions CollectionTransaction[]
  userMeta               CardUserMeta?
  binderOverride         BinderOverride?
  deckCards              DeckCard[]
  deckCardAllocations    DeckCardAllocation[]
  boosterOpeningCards    BoosterOpeningCard[]

  @@unique([setId, collectorNumber])
  @@index([setId])
}

model CardTranslation {
  id         String   @id @default(cuid())
  cardId     String
  card       Card     @relation(fields: [cardId], references: [id])
  locale     String
  name       String
  subtitle   String?
  rulesText  String?
  flavorText String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([cardId, locale])
  @@index([locale])
}

model CollectionEntry {
  id        String      @id @default(cuid())
  cardId    String
  card      Card        @relation(fields: [cardId], references: [id])
  variant   CardVariant
  quantity  Int         @default(0)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@unique([cardId, variant])
  @@index([variant])
}

model CollectionTransaction {
  id        String                    @id @default(cuid())
  cardId    String
  card      Card                      @relation(fields: [cardId], references: [id])
  variant   CardVariant
  type      CollectionTransactionType
  quantity  Int
  note      String?
  source    String?
  createdAt DateTime                  @default(now())

  @@index([cardId])
  @@index([variant])
  @@index([type])
  @@index([createdAt])
}

model CardUserMeta {
  id        String   @id @default(cuid())
  cardId    String   @unique
  card      Card     @relation(fields: [cardId], references: [id])
  favorite  Boolean  @default(false)
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BinderOverride {
  id        String             @id @default(cuid())
  cardId    String             @unique
  card      Card               @relation(fields: [cardId], references: [id])
  mode      BinderOverrideMode @default(AUTO)
  variant   CardVariant?
  quantity  Int?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  @@index([mode])
}

model Deck {
  id                 String                 @id @default(cuid())
  name               String
  status             DeckStatus             @default(THEORETICAL)
  description        String?
  allocationStrategy DeckAllocationStrategy @default(PRESERVE_PREMIUM_VARIANTS)
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  deckCards          DeckCard[]
  allocations        DeckCardAllocation[]

  @@index([status])
  @@index([createdAt])
  @@index([updatedAt])
}

model DeckCard {
  id               String                    @id @default(cuid())
  deckId           String
  deck             Deck                      @relation(fields: [deckId], references: [id], onDelete: Cascade)
  cardId           String
  card             Card                      @relation(fields: [cardId], references: [id])
  quantity         Int
  preferredVariant DeckCardVariantPreference @default(ANY)
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt

  @@unique([deckId, cardId, preferredVariant])
  @@index([deckId])
  @@index([cardId])
  @@index([preferredVariant])
}

model DeckCardAllocation {
  id        String      @id @default(cuid())
  deckId    String
  deck      Deck        @relation(fields: [deckId], references: [id], onDelete: Cascade)
  cardId    String
  card      Card        @relation(fields: [cardId], references: [id])
  variant   CardVariant
  quantity  Int
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@unique([deckId, cardId, variant])
  @@index([deckId])
  @@index([cardId])
  @@index([variant])
}

model BoosterSettings {
  id                     String              @id @default(cuid())
  boostersPerInterval    Int                 @default(1)
  intervalCount          Int                 @default(1)
  intervalUnit           BoosterIntervalUnit @default(DAY)
  accrualAnchorAt        DateTime
  autoDecrementOnOpening Boolean             @default(true)
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt

  @@index([intervalUnit])
}

model BoosterCounterEvent {
  id               String                  @id @default(cuid())
  type             BoosterCounterEventType
  quantityDelta    Int
  occurredAt       DateTime                @default(now())
  note             String?
  boosterOpeningId String?
  boosterOpening   BoosterOpening?         @relation(fields: [boosterOpeningId], references: [id], onDelete: SetNull)
  createdAt        DateTime                @default(now())

  @@index([type])
  @@index([occurredAt])
  @@index([boosterOpeningId])
}

model BoosterOpening {
  id               String                @id @default(cuid())
  openedAt         DateTime              @default(now())
  boosterCount     Int                   @default(1)
  decrementCounter Boolean               @default(true)
  status           BoosterOpeningStatus  @default(RECORDED)
  note             String?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  cards            BoosterOpeningCard[]
  counterEvents    BoosterCounterEvent[]

  @@index([openedAt])
  @@index([status])
  @@index([decrementCounter])
}

model BoosterOpeningCard {
  id               String         @id @default(cuid())
  boosterOpeningId String
  boosterOpening   BoosterOpening @relation(fields: [boosterOpeningId], references: [id], onDelete: Cascade)
  cardId           String
  card             Card           @relation(fields: [cardId], references: [id])
  variant          CardVariant
  quantity         Int
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@unique([boosterOpeningId, cardId, variant])
  @@index([boosterOpeningId])
  @@index([cardId])
  @@index([variant])
}
