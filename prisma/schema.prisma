generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum CardRarity {
  COMMON
  UNCOMMON
  RARE
  EPIC
  ULTIMATE
  UNKNOWN
}

enum CardKind {
  GAMEPLAY
  ENERGY
  TOKEN
  RULES
}

enum CardVariant {
  NORMAL
  FOIL
  SHOWCASE
}

enum CardPrintTreatment {
  REGULAR
  ALT
  OVERNUMBER
  UNKNOWN
}

enum CollectionTransactionType {
  ADD
  REMOVE
  SET
  ADJUST
}

enum BinderOverrideMode {
  AUTO
  DISABLED
  FORCE_VARIANT
}

model AppSetting {
  key       String   @id
  jsonValue String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Set {
  id         String    @id
  code       String    @unique
  name       String
  releasedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  cards      Card[]
}

model Card {
  id                     String                  @id
  setId                  String
  set                    Set                     @relation(fields: [setId], references: [id])
  collectorNumber        String?
  name                   String
  rarity                 CardRarity              @default(UNKNOWN)
  officialRarityRaw      String?
  kind                   CardKind
  printTreatment         CardPrintTreatment      @default(REGULAR)
  printTreatmentRaw      String?
  hasShowcase            Boolean                 @default(false)
  officialImageUrl       String?
  officialArtist         String?
  officialRawJson        Json?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  translations           CardTranslation[]
  collectionEntries      CollectionEntry[]
  collectionTransactions CollectionTransaction[]
  userMeta               CardUserMeta?
  binderOverride         BinderOverride?

  @@unique([setId, collectorNumber])
  @@index([setId])
}

model CardTranslation {
  id         String   @id @default(cuid())
  cardId     String
  card       Card     @relation(fields: [cardId], references: [id])
  locale     String
  name       String
  subtitle   String?
  rulesText  String?
  flavorText String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([cardId, locale])
  @@index([locale])
}

model CollectionEntry {
  id        String      @id @default(cuid())
  cardId    String
  card      Card        @relation(fields: [cardId], references: [id])
  variant   CardVariant
  quantity  Int         @default(0)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@unique([cardId, variant])
  @@index([variant])
}

model CollectionTransaction {
  id        String                    @id @default(cuid())
  cardId    String
  card      Card                      @relation(fields: [cardId], references: [id])
  variant   CardVariant
  type      CollectionTransactionType
  quantity  Int
  note      String?
  source    String?
  createdAt DateTime                  @default(now())

  @@index([cardId])
  @@index([variant])
  @@index([type])
  @@index([createdAt])
}

model CardUserMeta {
  id        String   @id @default(cuid())
  cardId    String   @unique
  card      Card     @relation(fields: [cardId], references: [id])
  favorite  Boolean  @default(false)
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BinderOverride {
  id        String             @id @default(cuid())
  cardId    String             @unique
  card      Card               @relation(fields: [cardId], references: [id])
  mode      BinderOverrideMode @default(AUTO)
  variant   CardVariant?
  quantity  Int?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  @@index([mode])
}
